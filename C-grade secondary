#define _CRT_SECURE_NO_WARNINGS
#define _WINSOCK_DEPRECATED_NO_WARNINGS

#include <stdio.h>
#include <stdlib.h>
#include <winsock2.h>
#include <windows.h>
#include <ws2tcpip.h>
#include <stdint.h>

#define PACKET_SIZE 1024
#define PAYLOAD_SIZE 1023
#define MAX_FILE_SIZE 10000000  // 10 MB max file size

#pragma comment(lib,"ws2_32.lib")

// New packet structure: 7 bits seq, 1 bit frag, 1023 payload
typedef struct {
    uint8_t header;            // MSB = fragmentation, lower 7 bits = sequence
    char payload[PAYLOAD_SIZE];
} Packet;

int main()
{
    WSADATA wsa;
    struct sockaddr_in server, si_other;
    SOCKET s;
    int slen = sizeof(si_other);
    int recv_len;

    char* buffer = (char*)malloc(MAX_FILE_SIZE); // reconstructed file
    if (!buffer) {
        printf("Memory allocation failed\n");
        return 1;
    }
    int totalBytes = 0;

    printf("\n****** INITIALIZING WINSOCK ***********\n");
    if (WSAStartup(MAKEWORD(2, 2), &wsa) != 0) {
        printf("Failed. Error Code : %d\n", WSAGetLastError());
        return 1;
    }
    printf("WINSOCK INITIALIZED\n");

    // CREATE SERVER SOCKET
    if ((s = socket(AF_INET, SOCK_DGRAM, 0)) == INVALID_SOCKET) {
        printf("Could not create socket : %d\n", WSAGetLastError());
        return 1;
    }
    printf("UDP SERVER SOCKET CREATED\n");

    server.sin_addr.s_addr = INADDR_ANY;
    server.sin_family = AF_INET;
    server.sin_port = htons(80);

    // BIND
    if (bind(s, (struct sockaddr*)&server, sizeof(server)) == SOCKET_ERROR) {
        printf("Bind failed with error code : %d\n", WSAGetLastError());
        return 1;
    }
    printf("SERVER SOCKET BIND SUCCESS\n");
    printf("Waiting for packets...\n");

    Packet pkt;
    int packetCount = 0;
    int moreFragments = 1;
    int currentOffset = 0;

    while (moreFragments) {
        recv_len = recvfrom(s, (char*)&pkt, sizeof(Packet), 0,
            (struct sockaddr*)&si_other, &slen);
        if (recv_len == SOCKET_ERROR) {
            printf("recvfrom() failed: %d\n", WSAGetLastError());
            continue;
        }

        // extract sequence number and fragmentation flag
        uint8_t seq = pkt.header & 0x7F;       // lower 7 bits
        moreFragments = (pkt.header & 0x80) >> 7; // MSB = 1 if more fragments

       // int offset = seq * PAYLOAD_SIZE;
        int payloadSize = recv_len - 1;
        memcpy(buffer + seq * PAYLOAD_SIZE, pkt.payload, payloadSize);
        currentOffset += payloadSize;
        // memcpy(buffer + offset, pkt.payload, recv_len - 1); // minus header byte
        // totalBytes += recv_len - 1;

        printf("Received packet %d, size %d, moreFragments=%d\n", seq, recv_len - 1, moreFragments);
        packetCount++;
    }

    // write reconstructed file


    FILE* writefp = fopen("test.jpg", "wb");
    if (!writefp) {
        printf("Error opening file for writing\n");
        free(buffer);
        return 1;
    }
    fwrite(buffer, 1, currentOffset, writefp);
    fclose(writefp);

    printf("File successfully reconstructed as test.jpg (%d packets, %d bytes)\n", packetCount, currentOffset);

    free(buffer);
    closesocket(s);
    WSACleanup();
    return 0;
}
