#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <inttypes.h>
#include <winsock2.h>
#include <windows.h>
#include <ws2tcpip.h>
#include <stdint.h>


#pragma comment(lib, "ws2_32.lib")

#define PACKET_SIZE 1024
#define MAX_DELAY 20000  

// Define packet structure
typedef struct {
    int seq;
    int size;
    char data[PACKET_SIZE];
} Packet;

typedef struct {
    int ack;
} Ack;

int main(void) {
    WSADATA wsa;
    if (WSAStartup(MAKEWORD(2, 2), &wsa) != 0) {
        printf("Failed. Error Code : %d\n", WSAGetLastError());
        return 1;
    }
    printf("WINSOCK INITIALIZED\n");

    SOCKET s;
    struct sockaddr_in si_other;
    int slen = sizeof(si_other);

    // Create UDP socket
    if ((s = socket(AF_INET, SOCK_DGRAM, 0)) == INVALID_SOCKET) {
        printf("Could not create socket : %d\n", WSAGetLastError());
        return 1;
    }
    printf("UDP CLIENT SOCKET CREATED.\n");

    // Non-blocking mode
    u_long noBlock = 1;
    ioctlsocket(s, FIONBIO, &noBlock);

    si_other.sin_family = AF_INET;
    si_other.sin_port = htons(80);
    si_other.sin_addr.s_addr = inet_addr("127.0.0.1");

    // Prepare data to send
    int fileLen = 5000;  // example file size
    char* buffer = (char*)malloc(fileLen);
    for (int i = 0; i < fileLen; i++) buffer[i] = 'A' + (i % 26); // dummy data

    int numPackets = (fileLen + PACKET_SIZE - 1) / PACKET_SIZE;
    Packet pkt;
    Ack ack;
    int seq = 0;

    LARGE_INTEGER frequency;
    QueryPerformanceFrequency(&frequency);

    // assume SOCKET setup, Packet/Ack definitions, buffer initialization are done

    LARGE_INTEGER start, current, frequency;
    QueryPerformanceFrequency(&frequency); 

    for (int i = 0; i < numPackets; i++) {
        int ackReceived = 0;

        while (!ackReceived) {
            sendto(s, (char*)&pkt, sizeof(Packet), 0,
                (struct sockaddr*)&si_other, slen);
            printf("Packet %d sent\n", pkt.seq);

            QueryPerformanceCounter(&start); // start timer

            while (1) {
                int recv_len = recvfrom(s, (char*)&ack, sizeof(Ack), 0,
                    (struct sockaddr*)&si_other, &slen);

                if (recv_len > 0 && ack.ack == pkt.seq) {
                    QueryPerformanceCounter(&current);
                    uint64_t elapsed = (uint64_t)(current.QuadPart - start.QuadPart);
                    printf("ACK %d received, elapsed = %" PRIu64 "\n", ack.ack, elapsed);
                    ackReceived = 1;
                    break;
                }

                // Check timeout
                QueryPerformanceCounter(&current);
                uint64_t elapsed = (uint64_t)(current.QuadPart - start.QuadPart);
                if (elapsed > MAX_DELAY) {
                    printf("Timeout for packet %d, retransmitting...\n", pkt.seq);
                    break; // resend packet
                }
            }
        }
        seq++;
    }
    free(buffer);
    closesocket(s);
    WSACleanup();
    return 0;
}
